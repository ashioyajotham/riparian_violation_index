# =============================================================================
# RVI-Kenya environment configuration
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# =============================================================================

# --- Google Flood Forecasting API (pilot access) -----------------------------
# Obtain via the pilot programme: https://developers.google.com/flood-forecasting
FLOODHUB_API_KEY=your-google-flood-hub-api-key
# Base URL is fixed in code but overridable here for testing/staging.
# FLOODHUB_BASE_URL=https://floodforecasting.googleapis.com/v1

# --- HTTP behaviour ----------------------------------------------------------
# Polite contact for OSM Overpass / Geofabrik / data providers.
RVI_USER_AGENT=rvi-kenya/0.1 (https://github.com/ashioyajotham/rvi-kenya)
RVI_REQUEST_TIMEOUT=120

# --- Paths -------------------------------------------------------------------
# Override the default ./data and ./outputs directories if desired.
# RVI_DATA_DIR=./data
# RVI_OUTPUTS_DIR=./outputs

# --- Geofabrik / OSM ---------------------------------------------------------
# Daily-updated Kenya extract used for the national-scale run.
GEOFABRIK_KENYA_PBF_URL=https://download.geofabrik.de/africa/kenya-latest.osm.pbf

# --- Microsoft Global ML Building Footprints --------------------------------
# Public dataset index (CSV listing of quadkey-tiled CSV.gz files).
MS_BUILDINGS_INDEX_URL=https://minedbuildings.z5.web.core.windows.net/global-buildings/dataset-links.csv
